<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PiTouchDate.Overlays"
             xmlns:controls="using:PiTouchDate.Controls"
             xmlns:utils="using:PiTouchDate.Utils.Converters"
             mc:Ignorable="d"
             Width="680" Height="340"
             x:Class="PiTouchDate.Overlays.WeatherSettingsView"
             x:DataType="vm:WeatherSettingsViewModel">

    <UserControl.Resources>
        <utils:NullToDoubleDashConverter x:Key="NullToDoubleDash"/>
    </UserControl.Resources>

    <Panel>

        <!-- Info view (default) -->
        <Grid IsVisible="{Binding !WeatherSettingsSelected}" RowDefinitions="Auto,*">

            <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                    Background="Transparent" BorderThickness="0"
                    Margin="0,4,4,0" Grid.Row="0"
                    Command="{Binding SelectWeatherSettingsCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="Impostazioni" Opacity="0.6"/>
                    <PathIcon Data="{DynamicResource SemiIconChevronRight}"
                              Width="12" Height="12" Opacity="0.4" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Grid Grid.Row="1" RowDefinitions="Auto,*" HorizontalAlignment="Stretch">

                <controls:Card Grid.Row="0" HorizontalContentAlignment="Stretch">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Panel Grid.Column="0" Margin="0,10,0,10" VerticalAlignment="Stretch">
                            <Image Source="{Binding WeatherData.WeatherIcon}" IsVisible="{Binding WeatherData.HasWeatherIcon}" Width="56" Height="56"/>
                            <PathIcon Data="{DynamicResource SemiIconMinus}" Height="2"
                                        IsVisible="{Binding !WeatherData.HasWeatherIcon}"/>
                        </Panel>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                            <TextBlock Text="{Binding CurrentTemperature, Converter={StaticResource NullToDoubleDash}, StringFormat='{}{0} °C'}" FontSize="32" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Opacity="0.7">
                                <TextBlock Text="{Binding Placement, Converter={StaticResource NullToDoubleDash}}" FontSize="18"/>
                                <TextBlock Text=" : " FontSize="18"/>
                                <TextBlock Text="{Binding WeatherDescription, Converter={StaticResource NullToDoubleDash}}" FontSize="18"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="{DynamicResource SemiIconArrowUp}" Width="15" Height="15"
                                          Foreground="{DynamicResource SemiRed5Color}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding WeatherData.MaxTemperature, Converter={StaticResource NullToDoubleDash}, StringFormat='{}{0} °C'}"
                                           FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SemiRed5Color}"/>
                            </StackPanel>
                            
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <PathIcon Data="{DynamicResource SemiIconArrowDown}" Width="15" Height="15"
                                            Foreground="{DynamicResource SemiBlue4Color}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding WeatherData.MinTemperature, Converter={StaticResource NullToDoubleDash}, StringFormat='{}{0} °C'}"
                                        FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SemiBlue4Color}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </controls:Card>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding WeatherInfoDayPeriods}" Margin="0,10,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <controls:Card HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                                <Grid RowDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Row="0" Text="{Binding TargetDayPeriod, Converter={StaticResource NullToDoubleDash}}"
                                        FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SemiBlue4Color}" HorizontalAlignment="Center"/>

                                    <Panel Grid.Row="1" Margin="0,20,0,20" VerticalAlignment="Stretch">
                                        <Image Source="{Binding WeatherIcon}" IsVisible="{Binding HasWeatherIcon}"/>
                                        <PathIcon Data="{DynamicResource SemiIconMinus}"
                                                  IsVisible="{Binding !HasWeatherIcon}"
                                                  Height="2" />
                                    </Panel>

                                    <TextBlock Grid.Row="2" Text="{Binding AverageTemperature, Converter={StaticResource NullToDoubleDash}, StringFormat='{}{0:F1} °C'}"
                                        FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource SemiWhiteColor}" HorizontalAlignment="Center"/>
                                </Grid>
                            </controls:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>
        </Grid>

        <!-- Settings view -->
        <Grid RowDefinitions="Auto, Auto, *" Margin="0,4,0,0"
              IsVisible="{Binding WeatherSettingsSelected}">

            <!-- Top bar: back + save -->
            <Grid Grid.Row="0" ColumnDefinitions="*, *">
                <Button Grid.Column="0" HorizontalAlignment="Left" Background="Transparent"
                        Command="{Binding SelectWeatherInfoCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Data="{DynamicResource SemiIconChevronLeft}" Width="14" Height="14" Opacity="0.4"/>
                        <TextBlock Text="Indietro"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" HorizontalAlignment="Right"
                        Command="{Binding SaveCommand}">
                    Salva
                </Button>
            </Grid>

            <!-- Coordinate field selectors -->
            <Grid Grid.Row="1" ColumnDefinitions="*, *" Margin="0,6,0,0">

                <!-- Latitude -->
                <Panel Grid.Column="0">
                    <controls:Card Command="{Binding SelectLatitudeCommand}"
                                   HorizontalContentAlignment="Stretch">
                        <StackPanel Margin="4,2">
                            <TextBlock Text="LATITUDINE" FontSize="10" FontWeight="Bold"
                                       LetterSpacing="0.5" Opacity="0.5"/>
                            <Panel Height="32" Margin="0,4,0,0">
                                <TextBlock Text="{Binding LatitudeInput}" FontSize="22" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding LatitudeInput, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <TextBlock Text="es. 45.4642" FontSize="16" Opacity="0.3"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding LatitudeInput, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                            </Panel>
                        </StackPanel>
                    </controls:Card>
                    <Border IsVisible="{Binding IsLatitudeActive}"
                            BorderBrush="{DynamicResource SemiBlue4Color}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Margin="4"
                            IsHitTestVisible="False"/>
                </Panel>

                <!-- Longitude -->
                <Panel Grid.Column="1">
                    <controls:Card Command="{Binding SelectLongitudeCommand}"
                                   HorizontalContentAlignment="Stretch">
                        <StackPanel Margin="4,2">
                            <TextBlock Text="LONGITUDINE" FontSize="10" FontWeight="Bold"
                                       LetterSpacing="0.5" Opacity="0.5"/>
                            <Panel Height="32" Margin="0,4,0,0">
                                <TextBlock Text="{Binding LongitudeInput}" FontSize="22" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding LongitudeInput, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                                <TextBlock Text="es. 9.1900" FontSize="16" Opacity="0.3"
                                           VerticalAlignment="Center"
                                           IsVisible="{Binding LongitudeInput, Converter={x:Static StringConverters.IsNullOrEmpty}}"/>
                            </Panel>
                        </StackPanel>
                    </controls:Card>
                    <Border IsVisible="{Binding IsLongitudeActive}"
                            BorderBrush="{DynamicResource SemiBlue4Color}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Margin="4"
                            IsHitTestVisible="False"/>
                </Panel>

            </Grid>

            <!-- Screen keyboard -->
            <controls:ScreenKeyboard Grid.Row="2" Margin="0,8,0,0"
                                     KeyPressCommand="{Binding KeyPressCommand}"/>

        </Grid>

    </Panel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PiTouchDate.Overlays"
             xmlns:controls="using:PiTouchDate.Controls"
             xmlns:models="using:SharpWifiManager"
             mc:Ignorable="d"
             Width="680" Height="340"
             x:Class="PiTouchDate.Overlays.WifiSettingsView"
             x:DataType="vm:WifiSettingsViewModel">

    <Panel>
        <Grid RowDefinitions="Auto, Auto, *" IsVisible="{Binding SelectedNetwork, Converter={x:Static ObjectConverters.IsNull}}">
            <!-- Scanning progress bar -->
            <ProgressBar Grid.Row="0" IsIndeterminate="True" IsVisible="{Binding Scanning}" 
                        Height="2" VerticalAlignment="Top" Foreground="{DynamicResource SemiBlue4Color}"/>

            <!-- Table header -->
            <Grid Grid.Row="1" ColumnDefinitions="*, 80, 40" Margin="15, 10, 15, 5" Opacity="0.5"
                  IsVisible="{Binding !IsRefreshError}">
                <TextBlock Grid.Column="0" Text="NOME RETE" FontSize="10" FontWeight="Bold" LetterSpacing="0.5"/>
                <TextBlock Grid.Column="1" Text="SEGNALE" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Networks list -->
            <Panel Grid.Row="2">
                <controls:Spinner IsVisible="{Binding IsRefreshError}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <ListBox IsVisible="{Binding !IsRefreshError}"
                         ItemsSource="{Binding Networks}"
                         Background="Transparent" BorderThickness="0" Margin="5,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:WifiNetwork">
                        <controls:Card Margin="0,2" Padding="12,10"
                                       Command="{Binding $parent[UserControl].((vm:WifiSettingsViewModel)DataContext).SelectNetwork}"
                                       CommandParameter="{Binding}"
                                       HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                            <Grid ColumnDefinitions="*, 80, 40">
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Ssid}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Security}" FontSize="11" Opacity="0.7"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="{Binding StrengthPercent, StringFormat={}{0}%}" 
                                        VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Medium"/>

                                <PathIcon Grid.Column="2" Data="{DynamicResource SemiIconChevronRight}" 
                                        Width="14" Height="14" Opacity="0.4" 
                                        VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </controls:Card>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListBox.Styles>
            </ListBox>
            </Panel>
        </Grid>

        <Grid IsVisible="{Binding SelectedNetwork, Converter={x:Static ObjectConverters.IsNotNull}}"
              HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              RowDefinitions="Auto, Auto, Auto, *">
            <!-- Control buttons -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,*" HorizontalAlignment="Stretch">
                <Button Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" 
                        Background="Transparent" Command="{Binding CancelConnectionCommand}"
                        IsEnabled="{Binding !IsConnecting}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PathIcon Data="{DynamicResource SemiIconChevronLeft}" Width="14" Height="14" Opacity="0.4" />
                        <TextBlock Text="Indietro"/>
                    </StackPanel>
                </Button>
                
                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Text="{Binding SelectedNetwork.Ssid}"/>
                
                <Button Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right"
                        Background="Transparent" Command="{Binding ConnectCommand}" IsEnabled="{Binding !IsConnecting}">
                        Connect
                </Button>
            </Grid>

            <!-- Password input -->
            <Panel Grid.Row="1" Margin="0,10,0,0">
                <TextBox HorizontalAlignment="Stretch"
                         PasswordChar="{Binding PasswordMaskChar}"
                         Text="{Binding WifiPassword, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12,8,44,8"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,6,0" Padding="6"
                        Background="Transparent" BorderThickness="0"
                        Command="{Binding ToggleShowPasswordCommand}">
                    <Panel>
                        <PathIcon Data="{DynamicResource SemiIconEyeOpened}"
                                  Width="18" Height="18" Opacity="0.6"
                                  IsVisible="{Binding !ShowPassword}"/>
                        <PathIcon Data="{DynamicResource SemiIconEyeClosedSolid}"
                                  Width="18" Height="18" Opacity="0.6"
                                  IsVisible="{Binding ShowPassword}"/>
                    </Panel>
                </Button>
            </Panel>

            <!-- Status message -->
            <Panel Grid.Row="2" Margin="4,6,4,0"
                   IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                <TextBlock Text="{Binding StatusMessage}"
                           IsVisible="{Binding !StatusIsError}"
                           Foreground="{DynamicResource SemiGreen5Color}"
                           TextWrapping="Wrap" FontSize="12"/>
                <TextBlock Text="{Binding StatusMessage}"
                           IsVisible="{Binding StatusIsError}"
                           Foreground="{DynamicResource SemiRed4Color}"
                           TextWrapping="Wrap" FontSize="12"/>
            </Panel>

            <!-- Screen keyboard -->
            <controls:ScreenKeyboard Grid.Row="3" Margin="0,10,0,0" KeyPressCommand="{Binding KeyPressCommand}"/>
        </Grid>
    </Panel>
</UserControl>

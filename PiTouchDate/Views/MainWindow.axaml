<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PiTouchDate.ViewModels"
        xmlns:controls="using:PiTouchDate.Controls"
        xmlns:overlays="using:PiTouchDate.Overlays"
        xmlns:utils="using:PiTouchDate.Utils.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="PiTouchDate.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Background="{DynamicResource Black}"
        Title="PiTouchDate"
        WindowDecorations="None"
        Width="780" Height="460">

    <Window.Resources>
        <utils:NullToDoubleDashConverter x:Key="NullToDoubleDash"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>


    <Panel>

        <Grid RowDefinitions="75*, 25*">
            <controls:Card Grid.Row="0">
                <Grid RowDefinitions="*,Auto">
                    <Viewbox Grid.Row="0" Margin="16,0,16,8">
                        <TextBlock Text="{Binding WeekDay}" Classes="H1" FontWeight="Bold"/>
                    </Viewbox>
                    <TextBlock Grid.Row="1" Text="{Binding CurrentDate}" HorizontalAlignment="Center"
                                Margin="8,0,8,8" Foreground="{DynamicResource SemiLightBlue6}" FontSize="80"/>
                </Grid>
            </controls:Card>
        
            <Grid Grid.Row="1" ColumnDefinitions="35*, 35*, 15*, 15*">
                <controls:Card Grid.Column="0">
                    <Viewbox Margin="8,8">
                        <TextBlock Text="{Binding CurrentTime}" FontWeight="Bold"/>
                    </Viewbox>
                </controls:Card>

                <controls:Card Grid.Column="1" Command="{Binding OnWeatherCardClicked}"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    
                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="16,0">
                        <Panel Grid.Column="0" Margin="0,10,0,10" VerticalAlignment="Stretch">
                            <Image Source="{Binding CurrentWeatherData.WeatherIcon}" IsVisible="{Binding CurrentWeatherData.HasWeatherIcon}"/>
                            <PathIcon Data="{DynamicResource SemiIconMinus}"
                                        IsVisible="{Binding !CurrentWeatherData.HasWeatherIcon}" Height="2"/>
                        </Panel>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                            <TextBlock Text="{Binding CurrentTemperature, Converter={StaticResource NullToDoubleDash}, StringFormat='{}{0} °C'}" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>

                        <PathIcon Grid.Column="2" 
                                Data="{DynamicResource SemiIconChevronRight}" 
                                Width="12" Height="12" 
                                Opacity="0.5"
                                VerticalAlignment="Center"/>
                    </Grid>
                </controls:Card>

                <controls:Card Grid.Column="2" Command="{Binding OnScreenModeCardClicked}">
                    <Border Padding="10">
                        <Panel>
                            <PathIcon Data="{DynamicResource SemiIconMoon}" Foreground="{DynamicResource SemiBlue5Color}" IsVisible="{Binding IsDayMode}"/>
                            <PathIcon Data="{DynamicResource SemiIconSun}" Foreground="{DynamicResource SemiYellow5Color}" IsVisible="{Binding !IsDayMode}"/>
                        </Panel>
                    </Border>
                </controls:Card>
                
                <controls:Card Grid.Column="3" Command="{Binding OnAppSettingsCardClicked}">
                    <Border Padding="10">
                        <PathIcon Data="{DynamicResource SemiIconSetting}" Foreground="{DynamicResource SemiGreen4}" />
                    </Border>
                </controls:Card>
            </Grid>
        </Grid>

        <controls:Overlay Title="{Binding CurrentOverlayTitle}"
                          Icon="{Binding CurrentOverlayIcon}"
                          IsVisible="{Binding IsOverlayVisible}"
                          CloseCommand="{Binding CloseOverlay}">
            <ContentControl Content="{Binding CurrentOverlay}"/>
        </controls:Overlay>
    </Panel>
</Window>
